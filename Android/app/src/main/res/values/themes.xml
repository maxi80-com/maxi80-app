<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- App theme. Window background is black (not the stock light/white) so the launch/splash
         screen and any pre-first-draw frame are fully black — matching the black launcher icon
         background instead of showing a white screen with a black rectangle behind the logo. -->
    <style name="Theme.Maxi80" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
    </style>
</resources>
