# This file contains the fastlane.tools configuration
# for the iOS half of the Skip app.
# You can find the documentation at https://docs.fastlane.tools

default_platform(:ios)

# ---------------------------------------------------------------------------
# Multi-platform note
#
# This is ONE App Store Connect record (App ID 335551519) with three platforms
# the maintainer created manually: iOS, macOS and tvOS. `deliver` /
# `upload_to_app_store` operates on ONE platform per run, selected by the
# `platform:` option ("ios" | "appletvos" | "osx"). Within that platform it
# classifies screenshots by resolution, so each platform needs its OWN
# screenshots folder tree:
#
#   fastlane/screenshots/ios/<locale>/       -> iPhone 6.9" (1320x2868 / 2868x1320)
#   fastlane/screenshots/appletv/<locale>/   -> Apple TV (1920x1080)
#   (macOS screenshots: TODO — no assets yet)
#
# Metadata text (fastlane/metadata/<locale>/*.txt) is shared across platforms:
# deliver uploads the same listing text to whichever platform the lane targets.
#
# There is a single Xcode target/scheme ("Maxi80 App") whose SUPPORTED_PLATFORMS
# covers iphoneos, appletvos and macosx (see Maxi80.xcodeproj) — i.e. one
# multiplatform binary, not separate schemes. `assemble` currently builds the
# iOS slice only (sdk: iphoneos). Binary upload for tvOS/macOS is left as a
# TODO (see the tvOS/macOS sections below).
# ---------------------------------------------------------------------------

lane :assemble do |options|
  # only build the iOS side of the app
  ENV["SKIP_ZERO"] = "true"
  build_app(
    scheme: "Maxi80 App",
    sdk: "iphoneos",
    xcconfig: "fastlane/AppStore.xcconfig",
    xcargs: "-skipPackagePluginValidation -skipMacroValidation",
    derived_data_path: "../.build/Darwin/DerivedData",
    output_directory: "../.build/fastlane/Darwin",
    skip_archive: ENV["FASTLANE_SKIP_ARCHIVE"] == "YES",
    skip_codesigning: ENV["FASTLANE_SKIP_CODESIGNING"] == "YES"
  )
end

# === iOS (iPhone) =========================================================

desc "iOS: push store listing (text + iPhone screenshots) as a DRAFT — no binary, no review"
lane :metadata do |options|
  # Uploads metadata/<locale>/*.txt and the iPhone screenshots to the iOS
  # App Store Connect listing without touching the binary and WITHOUT
  # submitting for review. Safe to run anytime; the listing sits as an
  # editable draft until you submit.
  upload_to_app_store(
    platform: "ios",
    screenshots_path: "fastlane/screenshots/ios",
    api_key_path: "fastlane/apikey.json",
    app_rating_config_path: "fastlane/metadata/rating.json",
    skip_binary_upload: true,
    submit_for_review: false,
    automatic_release: false,
    force: true,                          # skip the HTML preview confirmation
    precheck_include_in_app_purchases: false
  )
end

desc "iOS: build + upload the binary to TestFlight (staging — no App Store review)"
lane :beta do |options|
  get_provisioning_profile(api_key_path: "fastlane/apikey.json")
  assemble
  upload_to_testflight(
    api_key_path: "fastlane/apikey.json",
    skip_waiting_for_build_processing: true   # don't block on Apple's processing
  )
end

desc "iOS: full App Store submission — submits the current build FOR REVIEW (promote step)"
lane :release do |options|
  # see https://docs.fastlane.tools/uploading-app-privacy-details/
  #upload_app_privacy_details_to_app_store(json_path: "fastlane/app_privacy_details.json")

  # if you have an apikey.json file (https://developer.apple.com/documentation/appstoreconnectapi/creating-api-keys-for-app-store-connect-api), fastlane can automatically fetch certificates and the ASC authentication information
  #get_certificates(api_key_path: "fastlane/apikey.json")
  get_provisioning_profile(api_key_path: "fastlane/apikey.json")

  assemble

  upload_to_app_store(
    platform: "ios",
    screenshots_path: "fastlane/screenshots/ios",
    api_key_path: "fastlane/apikey.json",
    app_rating_config_path: "fastlane/metadata/rating.json",
    release_notes: { default: "Fixes and improvements." }
  )
end

# === tvOS (Apple TV) ======================================================

desc "tvOS: push store listing (text + Apple TV screenshots) as a DRAFT — no binary, no review"
lane :metadata_tvos do |options|
  # Same shared metadata text as iOS, but uploaded to the Apple TV platform
  # record with the Apple TV (1920x1080) screenshots. No binary, no review.
  upload_to_app_store(
    platform: "appletvos",
    screenshots_path: "fastlane/screenshots/appletv",
    api_key_path: "fastlane/apikey.json",
    app_rating_config_path: "fastlane/metadata/rating.json",
    skip_binary_upload: true,
    submit_for_review: false,
    automatic_release: false,
    force: true,                          # skip the HTML preview confirmation
    precheck_include_in_app_purchases: false
  )
end

