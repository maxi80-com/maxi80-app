# === macOS ================================================================

desc "macOS: push store listing (text + Mac screenshots) as a DRAFT — no binary, no review"
lane :metadata_mac do |options|
  # Same shared metadata text as iOS/tvOS, uploaded to the macOS platform record
  # with the Mac screenshots (2560x1600). No binary, no review.
  # sync_screenshots (checksum diff) instead of overwrite_screenshots — see the
  # note in the `metadata` lane. Without it deliver's upload→verify→retry races on
  # App Store Connect eventual-consistency and DUPLICATES every set (Mac showed 4
  # uploaded per 2-image set). Requires the beta feature flag set below.
  ENV["FASTLANE_ENABLE_BETA_DELIVER_SYNC_SCREENSHOTS"] = "1"
  upload_to_app_store(
    platform: "osx",
    # ABSOLUTE — see the note in the `metadata` lane. A relative path resolves
    # against CWD=Darwin/, i.e. the empty Darwin/screenshots/mac, so deliver
    # loaded 0 Mac screenshots and silently uploaded none.
    screenshots_path: File.expand_path("screenshots/mac", __dir__),
    api_key_path: "fastlane/apikey.json",
    app_rating_config_path: "fastlane/metadata/rating.json",
    skip_binary_upload: true,
    sync_screenshots: true,
    submit_for_review: false,
    automatic_release: false,
    force: true,                          # skip the HTML preview confirmation
    precheck_include_in_app_purchases: false
  )
end

